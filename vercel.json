{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/salesroadmap", "destination": "/salesroadmap.html" },
    { "source": "/investorroadmap", "destination": "/investorroadmap.html" },
    { "source": "/((?!roadmap\\.html$|salesroadmap\\.html$|investorroadmap\\.html$).*)", "destination": "/index.html" }
  ]
}
